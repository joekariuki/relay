# Required: Anthropic API key for the agent and evaluation framework
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI API key for voice pipeline (Whisper ASR + TTS)
OPENAI_API_KEY=sk-...

# Optional: Frontend URL for CORS (defaults to empty string)
FRONTEND_URL=https://your-frontend.vercel.app

# Optional: Environment name (defaults to "development")
ENVIRONMENT=development

# Optional: Log level (defaults to "INFO")
LOG_LEVEL=INFO
